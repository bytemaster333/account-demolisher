# Stellar network selection: "mainnet" | "testnet" | "futurenet"
NEXT_PUBLIC_STELLAR_NETWORK=testnet

# Public RPC endpoints (browser-readable). Override to self-host.
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org
NEXT_PUBLIC_RPC_URL=https://soroban-testnet.stellar.org

# Deployment mode: "reference" uses server-side mediator; "self-hosted" uses
# per-flow client-generated ephemeral mediator (see plan.md Phase 4).
NEXT_PUBLIC_DEPLOYMENT_MODE=reference

# Refractor coordinator (browser-readable; no credentials required).
NEXT_PUBLIC_REFRACTOR_URL=https://api.refractor.space

# --- SERVER-ONLY VARIABLES (never expose to the client) ---

# Mediator account secret (S...). Required only when deployment mode is "reference".
# Generate per-deployment; never share. Keypair derives the mediator public key.
MEDIATOR_SECRET=

# Orion (Daccred) DeFi Positions API. Stub-only until upstream publishes (see Phase 10).
ORION_API_URL=
ORION_API_KEY=

# OctoPos (Untangled Finance) DeFi Positions API. Stub-only until upstream publishes.
OCTOPOS_API_URL=
OCTOPOS_API_KEY=

# Soroswap routing API. Server-proxied to conceal the key from the client.
SOROSWAP_API_URL=https://api.soroswap.finance
SOROSWAP_API_KEY=
